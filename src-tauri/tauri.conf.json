{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GameCraft AI Studio",
  "version": "0.1.0",
  "identifier": "com.gamecraft.ai.studio",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 5273 --strictPort",
    "devUrl": "http://127.0.0.1:5273",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GameCraft AI Studio",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
